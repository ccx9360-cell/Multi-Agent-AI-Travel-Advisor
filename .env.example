# ── Required ─────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── Flight APIs ──────────────────────────────────────────────────────────────
# Amadeus (primary) — https://developers.amadeus.com/self-service
AMADEUS_API_KEY=your_amadeus_api_key_here
AMADEUS_API_SECRET=your_amadeus_api_secret_here

# SerpApi (fallback) — https://serpapi.com/
SERPAPI_KEY=your_serpapi_key_here

# ── Accommodation APIs ───────────────────────────────────────────────────────
# Booking.com via RapidAPI — https://rapidapi.com/DataCrawler/api/booking-com15
BOOKING_API_KEY=your_rapidapi_key_here

# Airbnb via RapidAPI — https://rapidapi.com/3b-data-3b-data-default/api/airbnb19
AIRBNB_API_KEY=your_rapidapi_key_here

# ── Activity APIs ────────────────────────────────────────────────────────────
# Google Places — https://developers.google.com/maps/documentation/places
GOOGLE_PLACES_API_KEY=your_google_api_key_here

# Viator — https://docs.viator.com/partner-api/technical
VIATOR_API_KEY=your_viator_api_key_here

# Yelp Fusion — https://docs.developer.yelp.com/
YELP_API_KEY=your_yelp_api_key_here

# ── Logistics APIs ───────────────────────────────────────────────────────────
# Google Maps Directions — https://developers.google.com/maps/documentation/directions
GOOGLE_MAPS_API_KEY=your_google_api_key_here

# OpenWeatherMap — https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweather_api_key_here

# Exchange Rate (optional) — https://exchangerate.host/
EXCHANGE_RATE_API_KEY=

# ── RAG Embeddings ───────────────────────────────────────────────────────────
# OpenAI (for text-embedding-ada-002) — only needed for RAG knowledge base
OPENAI_API_KEY=your_openai_api_key_here

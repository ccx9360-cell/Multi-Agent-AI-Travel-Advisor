# ── 中国旅行助手 — 环境变量配置 ──────────────────────────────────
# 将本文件复制为 .env 并填入真实值
# cp .env.example .env

# ── 必需 ───────────────────────────────────────────────────────
# LLM API Key（Gemini / OpenAI 任选其一）
GEMINI_API_KEY=your_gemini_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here

# ── 高德地图 Web服务 API ───────────────────────────────────────
# 注册: https://lbs.amap.com/ （个人开发者免费）
# 用途: POI搜索/路线规划/天气查询
AMAP_API_KEY=your_amap_api_key_here

# ── 美团酒旅 ───────────────────────────────────────────────────
# Token 放在外部文件，此路径为默认位置
# MEITUAN_CONFIG=~/.config/meituan-travel/config.json

# ── 12306 火车票 ───────────────────────────────────────────────
# 12306B 微服务地址（如独立部署）
# TRAIN_API_URL=http://localhost:8001

# ── RAG 知识库 ─────────────────────────────────────────────────
# ChromaDB 存储路径（可选，有默认值）
# KNOWLEDGE_CHROMA_PATH=~/.hermes/chroma_db

# ── 服务配置（可选） ──────────────────────────────────────────
# APP_HOST=0.0.0.0
# APP_PORT=8000
# CORS_EXTRA_ORIGINS=http://192.168.100.3:5173,http://192.168.100.4:5173
